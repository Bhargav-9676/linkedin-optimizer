# ============================================================
#  LinkedIn Profile Optimizer — API Keys Configuration
#  Keep this file PRIVATE. Never commit to git.
# ============================================================

# ── GROQ API KEY (FREE - Primary AI Provider) ──────────────
# Get yours FREE at: https://console.groq.com
# No credit card required. 6000 requests/day free.
GROQ_API_KEY=your_groq_api_key_here

# ── GROQ MODEL ─────────────────────────────────────────────
# Options: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
# llama3-8b-8192 = fastest + cheapest (recommended)
# llama3-70b-8192 = better quality, slower
GROQ_MODEL=llama3-8b-8192

# ── APP SETTINGS ───────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=true
SECRET_KEY=linkedin-optimizer-secret-2024

# ── OPTIONAL: Claude API (paid fallback if Groq fails) ─────
# Only needed if you want Claude as backup
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=
